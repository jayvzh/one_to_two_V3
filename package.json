{
  "name": "one_to_two_v3",
  "version": "1.0.0",
  "description": "一进二策略分析系统 - Electron + React + Vite + TypeScript Desktop Application",
  "main": "./out/main/index.js",
  "author": "OneToTwo Team",
  "license": "MIT",
  "type": "module",
  "homepage": ".",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:renderer": "vite build",
    "build:electron": "electron-vite build",
    "build:python": "node scripts/build-python.js",
    "build:python-exe": "node scripts/build-python-exe.js",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "postinstall": "node scripts/postinstall.js",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && npm run build:python-exe && electron-builder --win --config",
    "build:win:quick": "npm run build && electron-builder --win --config",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config",
    "build:all": "npm run build && electron-builder --win --mac --linux --config",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "antd": "^5.22.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "less": "^4.2.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
